    <!-- ── Privacy policy ───────────────────────────────────── -->
    <string name="privacy_title">Privacy Policy</string>
    <string name="privacy_last_update">Last updated: May 2026</string>
    <string name="privacy_s1_title">1. About the app</string>
    <string name="privacy_s1_body">CuidadoPet is a pet care organisation app. The app is local — all data is stored exclusively on the user\'s device. There are no servers, user accounts or cloud sync.</string>
    <string name="privacy_s2_title">2. Data collected</string>
    <string name="privacy_s2_body">CuidadoPet does not collect or transmit any personal or health data to external servers.\n\nThe following data is created and stored ONLY locally on the device:\n• Pet name, species, breed and weight\n• Medication records and administration times\n• Feeding plans and meal logs\n• Hydration records\n• Health diary entries and weight history\n• Pet photo (saved in the app\'s internal storage)</string>
    <string name="privacy_s3_title">3. App permissions</string>
    <string name="privacy_s3_body">• Notifications: to send medication and meal reminders\n• Exact alarms: to ensure reminders are on time\n• Camera: to take a pet photo (optional)\n• Image access: to choose a photo from the gallery (optional)\n• Boot receiver: to reschedule alarms after restart</string>
    <string name="privacy_s4_title">4. Data sharing</string>
    <string name="privacy_s4_body">The app does not share data with third parties automatically.\n\nOwners may choose to share reports manually (WhatsApp, email, etc.) using the export functions. This sharing is always initiated by the user\'s explicit action.</string>
    <string name="privacy_s5_title">5. Veterinary disclaimer</string>
    <string name="privacy_s5_body">CuidadoPet is a personal organisation tool and does NOT replace veterinary evaluation, diagnosis or prescription. Information recorded in the app represents the owner\'s observations and must not be used as a basis for medical decisions without professional guidance.</string>
    <string name="privacy_s6_title">6. Data retention and deletion</string>
    <string name="privacy_s6_body">All data stays on the device. To delete data, the user can uninstall the app, which removes all files and the local database.</string>
    <string name="privacy_s7_title">7. Minors</string>
    <string name="privacy_s7_body">The app does not collect data from minors. It is intended for adult owners responsible for their animals.</string>
    <string name="privacy_s8_title">8. Contact</string>
    <string name="privacy_s8_body">Questions about this policy can be sent to the developer\'s support email available on the app\'s Google Play page.</string>

