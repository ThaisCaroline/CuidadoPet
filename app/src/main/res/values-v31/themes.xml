<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- No Android 12+ (API 31+) o sistema lê os atributos nativos android: antes que a
         biblioteca compat possa agir. Este arquivo garante que o splash use o ícone correto
         e o fundo teal nessas versões. -->
    <style name="Theme.CuidadoPet.Splash" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.CuidadoPet</item>
    </style>

</resources>
